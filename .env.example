# ── Server (Node.js backend — Phase 2+) ──────────────────────────────────────
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DEEPGRAM_API_KEY=
RESEND_API_KEY=
PORT=3001

# ── Frontend (Vite — must be prefixed with VITE_) ─────────────────────────────
# Copy to app/.env.local and fill in values from Supabase project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# During local dev with Cloudflare Tunnel, replace with the tunnel URL
VITE_API_BASE_URL=http://localhost:3001
