ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # alias used in some routes — set same value as SUPABASE_SERVICE_KEY
DEEPGRAM_API_KEY=
RESEND_API_KEY=
ADMIN_PASSWORD=               # login for /admin dashboard (username always "admin")
PORT=3001

# Update-checker (production only — drives GET /api/version)
# APP_VERSION=0.2.0
# APK_URL=https://github.com/randommonicle/ash-inspection-app/releases/download/v0.2.0/app-release.apk
# RELEASE_NOTES=
# FORCE_UPDATE=false

# FORWARD: PROD-GATE — dev/field-test only. With this set, ALL reports route
# to one address regardless of inspector. Remove before client-facing use.
# REPORT_TO_OVERRIDE=

# Click-to-enlarge photo links in the PDF (off by default). When "true", every
# photo in the report is wrapped in a 10-year signed Supabase URL so tapping it
# opens the full-res image in a browser. Caveat: rotating the Supabase service
# key invalidates the URLs in every previously-sent report. See CLAUDE.md.
# ENABLE_PHOTO_HYPERLINKS=false
