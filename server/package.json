{
  "name": "ash-inspection-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file=.env node_modules/tsx/dist/cli.mjs watch index.ts",
    "restart": "npx kill-port 3001 && node --env-file=.env node_modules/tsx/dist/cli.mjs watch index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "test:unit": "node --require ./node_modules/tsx/dist/cjs/index.cjs --test tests/unit.test.ts",
    "test:integration": "node --env-file=.env --require ./node_modules/tsx/dist/cjs/index.cjs --test tests/integration.test.ts",
    "test": "npm run test:unit",
    "backfill-photos": "node --env-file=.env node_modules/tsx/dist/cli.mjs scripts/backfill-photo-analysis.ts",
    "backup-db": "node --env-file=.env scripts/backup-database.mjs",
    "backup-storage": "node --env-file=.env scripts/backup-storage.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.43.4",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.0",
    "node-cron": "^4.2.1",
    "resend": "^6.12.2",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
